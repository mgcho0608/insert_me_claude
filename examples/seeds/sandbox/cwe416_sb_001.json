{
  "schema_version": "1.0",
  "seed_id": "cwe416-sandbox-list-insert-after-001",
  "seed": 1,
  "cwe_id": "CWE-416",
  "vulnerability_class": "Use After Free",
  "description": "Insert a use-after-free in list_insert_after(): free() the newly-allocated node immediately before its next/prev fields are written in the else-branch, turning the subsequent arrow-dereferences into uses of freed memory.",
  "mutation_strategy": "insert_premature_free",
  "target_pattern": {
    "pattern_type": "pointer_deref",
    "require_function_scope": true,
    "min_candidate_score": 0.6,
    "constraints": {
      "require_prior_malloc_in_scope": true,
      "min_deref_distance_from_alloc": 3,
      "require_no_existing_free_between": true
    }
  },
  "source_constraints": {
    "file_patterns": ["*.c", "*.cpp"],
    "exclude_patterns": ["*test*", "*_test.*", "*mock*", "*stub*"],
    "max_targets": 1
  },
  "metadata": {
    "tags": ["heap", "use-after-free", "temporal", "sandbox-eval"],
    "difficulty": "medium",
    "notes": "Targets list_insert_after() in list.c — node allocated then freed before else-branch field writes.",
    "references": ["https://cwe.mitre.org/data/definitions/416.html"]
  }
}
